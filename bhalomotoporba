            p.style.animationDelay = Math.random() * 0.6 + 's';
            document.body.appendChild(p);
            p.addEventListener('animationend', () => p.remove());
        }
    }

    function renderCurrentQuestion() {
        if (currentQIndex >= totalQuestions) {
            if (score === totalQuestions) showGrandFinale();
            else resetQuiz();
            return;
        }
        const q = quizData[currentQIndex];
        questionText.innerText = q.question;
        progressSpan.innerText = `Question ${currentQIndex+1}/${totalQuestions}  ❤️ Score: ${score}/${totalQuestions}`;
        answersArea.innerHTML = '';
        const isMulti = Array.isArray(q.correct);
        q.answers.forEach((ans, idx) => {
            const div = document.createElement('div');
            div.className = 'answer-option';
            const input = document.createElement('input');
            input.type = isMulti ? 'checkbox' : 'radio';
            input.name = 'quizOption';
            input.value = idx;
            input.id = `opt_${idx}`;
            const label = document.createElement('label');
            label.htmlFor = `opt_${idx}`;
            label.innerText = ans;
            div.appendChild(input);
            div.appendChild(label);
            div.addEventListener('click', (e) => {
                if(e.target.tagName !== 'INPUT') input.click();
            });
            answersArea.appendChild(div);
        });
        waitingSubmit = false;
    }

    function evaluateAndSubmit() {
        if (waitingSubmit) return;
        const q = quizData[currentQIndex];
        const isMulti = Array.isArray(q.correct);
        let selected = [];
        const allInputs = answersArea.querySelectorAll('input');
        allInputs.forEach(inp => { if(inp.checked) selected.push(parseInt(inp.value)); });
        if(selected.length === 0) return;

        let correctFlag = false;
        if(isMulti) {
            const correctSet = new Set(q.correct);
            if(selected.length === correctSet.size && selected.every(v => correctSet.has(v))) correctFlag = true;
        } else {
            if(selected.length === 1 && selected[0] === q.correct) correctFlag = true;
        }

        if(!correctFlag) {
            showTrashAndGameOver();
            return;
        }
        // correct answer
        waitingSubmit = true;
        createFallingPetals();
        score++;
        currentQIndex++;
        if(score === totalQuestions) {
            showGrandFinale();
            return;
        }
        renderCurrentQuestion();
        waitingSubmit = false;
    }

    function showGrandFinale() {
        quizSection.style.display = 'none';
        gameOverSection.style.display = 'none';
        giftSection.style.display = 'block';
        const mysteryDiv = document.getElementById('mysteryBoxStage');
        const photoStageDiv = document.getElementById('photoStage');
        mysteryDiv.style.display = 'block';
        photoStageDiv.style.display = 'none';
        document.getElementById('foldedLetterArea').innerHTML = '';
        const openBtn = document.getElementById('openMysteryBox');
        const newBtn = openBtn.cloneNode(true);
        openBtn.parentNode.replaceChild(newBtn, openBtn);
        newBtn.addEventListener('click', () => {
            mysteryDiv.style.display = 'none';
            photoStageDiv.style.display = 'block';
            initPhotoStack();
        });
    }

    function initPhotoStack() {
        const stackContainer = document.getElementById('photoStackDiv');
        const foldedContainer = document.getElementById('foldedLetterArea');
        stackContainer.innerHTML = '';
        foldedContainer.innerHTML = '';
        let photosRemaining = [...photoGallery];
        function rebuildStack() {
            stackContainer.innerHTML = '';
            if(photosRemaining.length === 0) {
                const paper = document.createElement('div');
                paper.className = 'folded-paper';
                paper.innerHTML = `<p>📜 A secret letter waits...<br> ✨ click to unfold ✨</p>`;
                paper.style.cursor = 'pointer';
                paper.addEventListener('click', () => {
                    paper.innerHTML = `<div class="final-love-text">💖 ${finalLoveMessage} 💖</div>`;
                    paper.style.cursor = 'default';
                });
                foldedContainer.appendChild(paper);
                return;
            }
            photosRemaining.forEach((url, idx) => {
                const card = document.createElement('div');
                card.className = 'photo-card';
                const img = document.createElement('img');
                img.src = url;
                img.alt = 'our memory';
                card.appendChild(img);
                stackContainer.appendChild(card);
                attachSwipe(card, idx);
            });
        }
        function attachSwipe(card, idx) {
            let startX = 0, currentX = 0, isDragging = false;
            const onMove = (e) => {
                if(!isDragging) return;
                currentX = e.clientX;
                const delta = currentX - startX;
                card.style.transform = `translateX(${delta}px) rotate(${delta*0.03}deg)`;
                card.style.transition = 'none';
            };
            const onUp = (e) => {
                if(!isDragging) return;
                const delta = currentX - startX;
                card.style.transition = 'transform 0.2s ease';
                if(Math.abs(delta) > 70) {
                    card.style.transform = `translateX(${delta>0?'500px':'-500px'})`;
                    setTimeout(() => {
                        photosRemaining.splice(idx,1);
                        rebuildStack();
                    }, 150);
                } else {
                    card.style.transform = '';
                }
                window.removeEventListener('pointermove', onMove);
                window.removeEventListener('pointerup', onUp);
                isDragging = false;
                card.style.cursor = 'grab';
            };
            card.addEventListener('pointerdown', (e) => {
                e.preventDefault();
                startX = e.clientX;
                isDragging = true;
                card.style.cursor = 'grabbing';
                window.addEventListener('pointermove', onMove);
                window.addEventListener('pointerup', onUp);
            });
        }
        rebuildStack();
    }

    submitBtn.addEventListener('click', evaluateAndSubmit);
    resetGameBtn.addEventListener('click', resetQuiz);
    resetQuiz();
</script>
</body>
</html>
